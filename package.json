{
  "name": "ucollab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "services:up": "docker compose up -d",
    "services:down": "docker compose down",
    "services:logs": "docker compose logs -f",
    "predev": "tsx scripts/check-dev-setup.ts",
    "dev": "next dev & npx prisma studio --browser none",
    "build": "next build",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "start": "next start",
    "test:unit": "vitest run --config src/tests/config/vitest.unit.config.ts",
    "test:unit:watch": "vitest --config src/tests/config/vitest.unit.config.ts",
    "test:integration": "vitest run --config src/tests/config/vitest.integration.config.ts",
    "test:e2e": "playwright test --config src/tests/config/playwright.config.ts",
    "test:e2e:smoke": "playwright test --config src/tests/config/playwright.config.ts --project=smoke",
    "test:coverage": "vitest run --coverage --config src/tests/config/vitest.unit.config.ts",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "db:generate": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:init": "prisma db push && prisma db seed",
    "db:clean": "prisma db push --force-reset",
    "postinstall": "prisma generate",
    "db:seed": "prisma db seed",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "tsx src/data/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@aws-sdk/client-s3": "^3.714.0",
    "@dicebear/collection": "^9.2.2",
    "@dicebear/core": "^9.2.2",
    "@eslint/eslintrc": "^3.2.0",
    "@octokit/rest": "^21.1.0",
    "@prisma/client": "^6.2.1",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.5",
    "@radix-ui/react-dropdown-menu": "^2.1.5",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.4",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.1.7",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.7",
    "bullmq": "^5.34.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv-cli": "^8.0.0",
    "eslint-config-next": "^15.1.5",
    "fumadocs-core": "^15.0.1",
    "fumadocs-ui": "^15.0.1",
    "geist": "^1.3.1",
    "http-status-codes": "^2.3.0",
    "lucide-react": "^0.473.0",
    "motion": "^11.18.2",
    "next": "^15.1.4",
    "next-auth": "^5.0.0-beta.25",
    "next-themes": "^0.4.4",
    "posthog-js": "^1.210.2",
    "posthog-node": "^4.4.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swr": "^2.3.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/eslint": "^9.6.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^3.0.2",
    "eslint-config-prettier": "^10.0.1",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.1",
    "prettier": "3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "prisma": "^6.2.1",
    "prisma-generator-fake-data": "^0.14.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.2"
  }
}
